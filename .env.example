# ── Core audio / streaming ───────────────────────────────────────────
SAMPLE_RATE=16000
CHANNELS=2
CHUNK_SECONDS=2.0
OVERLAP_SECONDS=0.3
ROLLING_WINDOW_SECONDS=4.0
MAX_BUFFER_SECONDS=8.0

# ── Transcript stability ────────────────────────────────────────────
STABLE_COMMIT_SECONDS=2.5

# ── Queue / back-pressure ───────────────────────────────────────────
QUEUE_DROP_THRESHOLD=60
MAX_BATCH_JOBS=4
GPU_WORKER_COUNT=1

# ── Adaptive quality (auto-degrade under GPU pressure) ──────────────
ADAPTIVE_QUALITY=true
ADAPTIVE_QUEUE_THRESHOLD=20
FAST_BEAM_SIZE=1
FAST_PATIENCE=1.0
FAST_WORD_TIMESTAMPS=false

# ── VAD ─────────────────────────────────────────────────────────────
VAD_MODE=3
VAD_FRAME_MS=30
VAD_SILENCE_SECONDS=0.35
VAD_ENERGY_THRESHOLD=0.03

# ── Whisper / GPU ───────────────────────────────────────────────────
WHISPER_MODEL=turbo
WHISPER_DEVICE=cuda
CUDA_DEVICE_INDEX=0
WHISPER_COMPUTE_TYPE=int8_float16
CUDA_VISIBLE_DEVICES=0
OMP_NUM_THREADS=4
CT2_CUDA_ALLOW_TF32=1
LD_LIBRARY_PATH=/usr/local/cuda-13.0/targets/x86_64-linux/lib

# ── Whisper quality tuning ──────────────────────────────────────────
WHISPER_LANGUAGE=en
WHISPER_BEAM_SIZE=5
WHISPER_TEMPERATURE=0.0
WHISPER_NO_SPEECH_THRESHOLD=0.6
WHISPER_CONDITION_ON_PREVIOUS=true
HALLUCINATION_FILTER=true

# ── Advanced Whisper quality tuning ─────────────────────────────────
WHISPER_REPETITION_PENALTY=1.15
WHISPER_NO_REPEAT_NGRAM_SIZE=3
WHISPER_PATIENCE=1.5
WHISPER_WORD_TIMESTAMPS=true
WHISPER_HALLUCINATION_SILENCE_THRESHOLD=1.0
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
WHISPER_LOG_PROB_THRESHOLD=-1.0
WHISPER_LENGTH_PENALTY=1.0
# Uncomment and set domain-specific terms to boost recognition of proper nouns
# WHISPER_HOTWORDS=Benoni,mitkadmim,tuchus

# ── Session lifecycle & guardrails ──────────────────────────────────
SESSION_IDLE_TIMEOUT_SECONDS=20
SESSION_MAX_DURATION_SECONDS=14400
CLEANUP_INTERVAL_SECONDS=5
MAX_CONCURRENT_SESSIONS=100
MAX_FRAME_BYTES=32768
WS_SEND_TIMEOUT_SECONDS=2.0

# ── Utterance-based mode ────────────────────────────────────────────
MIN_UTTERANCE_DURATION_SEC=0.3
MIN_INTERIM_INTERVAL_SEC=1.5
MAX_UTTERANCE_DURATION_SEC=6.0
MIN_SPEECH_FRAMES=2
MIN_SILENCE_FRAMES=15

# ── Optional auth (leave empty to disable) ──────────────────────────
API_KEY=
